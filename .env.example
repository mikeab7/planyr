# Supabase backend (Phase 1: connection only).
# Copy this file to .env.local for local dev, and set the SAME variable names as
# GitHub Actions repository secrets for the live build (see .github/workflows/build.yml).
# These files are gitignored — do NOT commit real values.
#
# Note: the anon/public key is SAFE to expose in a frontend bundle. It is public by
# design and only grants what Row-Level Security allows (RLS is a later phase). We
# still keep it in env (not committed) per the repo secrets rule.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
