# Supabase backend (Phase 1: connection only).
# Copy this file to .env.local for local dev, and set the SAME variable names as
# GitHub Actions repository secrets for the live build (see .github/workflows/build.yml).
# These files are gitignored — do NOT commit real values.
#
# Note: the anon/public key is SAFE to expose in a frontend bundle. It is public by
# design and only grants what Row-Level Security allows (RLS is a later phase). We
# still keep it in env (not committed) per the repo secrets rule.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Mapillary street-level pole/hydrant detections (B308) — SERVER-SIDE ONLY, never commit.
# Set as an encrypted Secret named MAPILLARY_TOKEN in Cloudflare Pages → project "planyr"
# → Production (add it to Preview too if you want per-branch preview URLs to show the
# layer). The /api/mapillary proxy reads it from the Pages Functions runtime
# (context.env.MAPILLARY_TOKEN) — it is NOT a VITE_* var (that would bake the token into
# the public bundle). Absent → the layer degrades gracefully (no street imagery), no error.
MAPILLARY_TOKEN=server-side-only-set-as-an-encrypted-secret-in-cloudflare-pages
